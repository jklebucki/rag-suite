{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileLogging": {
    "Path": "logs/rag-orchestrator-.txt",
    "RollingInterval": "Day",
    "RetainedFileCountLimit": 7,
    "RerankCurlPath": "logs/rerank-curl-.txt"
  },
  "Frontend": {
    "BaseUrl": "https://app.rag-suite.example"
  },
  "ConnectionStrings": {
    "SecurityDatabase": "Host=localhost;Database=rag-suite;Username=postgres;Password=postgres"
  },
  "Services": {
    "Elasticsearch": {
      "Url": "http://localhost:9200",
      "Username": "elastic",
      "Password": "elastic",
      "TimeoutMinutes": 10,
      "DefaultIndexName": "rag-chunks",
      "AutoCreateIndices": false,
      "AlwaysReconstructFullDocuments": true,
      "MinimumChunkCompleteness": 0.8,
      "MaxChunksPerDocument": 1000
    },
    "EmbeddingService": {
      "Url": "http://192.168.21.14:8580",
      "QueryPrefix": ""
    },
    "RerankService": {
      "Url": "http://192.168.21.14:8582",
      "Enabled": true,
      "Api": "cohere",
      "Model": "BAAI/bge-reranker-v2-m3",
      "RetrieveTopN": 40,
      "MaxDocumentChars": 1800,
      "TimeoutSeconds": 30
    },
    "LlmService": {
      "Url": "http://192.168.21.14:11434",
      "MaxTokens": 3000,
      "Temperature": 0.7,
      "Model": "llama3.1:8b-instruct-q8_0",
      "IsOllama": true,
      "TimeoutMinutes": 15,
      "ContextWindow": 98000,
      "AttachmentContextLimitTokens": 12000,
      "SessionContextLimitTokens": 9600
    },
    "Forum": {
      "EnableAttachments": true,
      "MaxAttachmentCount": 5,
      "MaxAttachmentSizeMb": 5,
      "EnableEmailNotifications": true,
      "BadgeRefreshSeconds": 60
    }
  },
  "Chat": {
    "RequestTimeoutMinutes": 15
  },
  "DefaultAdmin": {
    "Email": "admin@citronex.pl",
    "Password": "Citro@123"
  }
}
